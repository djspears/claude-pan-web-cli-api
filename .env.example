# Copy to .env for local development (never commit .env)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Palo Alto Networks AI Runtime Security
# Leave PAN_API_KEY empty to run without PAN inspection (prompts pass through)
PAN_API_KEY=YOUR_PAN_API_KEY_HERE
PAN_API_URL=https://service.api.aisecurity.paloaltonetworks.com
PAN_APP_NAME=claude-proxy
PAN_PROFILE_NAME=default
PAN_TIMEOUT=10
PAN_SCAN_RESPONSES=false

# Claude
CLAUDE_MODEL=claude-haiku-4-5

# App
LOG_LEVEL=INFO
